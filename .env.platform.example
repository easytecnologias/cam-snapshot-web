# Copy this file to .env.platform before running docker-compose.platform.yml.

TZ=America/Sao_Paulo
APP_ENV=production
ENABLE_DOCS=0
AUTH_REQUIRED=1
AUTH_LEGACY_OPEN=0
ENABLE_LEGACY_STATE_IMPORT=0

# Use the published image for production.
CAM_SNAPSHOT_IMAGE=ghcr.io/easytecnologias/cam-snapshot-web:latest

# Public ports on the Docker host.
SIGHTOPS_HTTP_PORT=80
SIGHTOPS_POSTGRES_PORT=5432
ZABBIX_WEB_PORT=8081
ZABBIX_SERVER_PORT=10051
GRAFANA_PORT=3000

# Restrict this to the real URL in production.
ALLOWED_ORIGINS=http://localhost
TRUSTED_PROXIES=127.0.0.1

# SightOps database.
SIGHTOPS_DB=sightops
SIGHTOPS_DB_USER=sightops
SIGHTOPS_DB_PASSWORD=change-this-sightops-password

# Zabbix database.
ZABBIX_DB=zabbix
ZABBIX_DB_USER=zabbix
ZABBIX_DB_PASSWORD=change-this-zabbix-password

# Zabbix tuning.
ZBX_CACHESIZE=256M
ZBX_HISTORYCACHESIZE=128M
ZBX_TRENDCACHESIZE=128M
ZBX_VALUECACHESIZE=128M
ZABBIX_AGENT_HOSTNAME=sightops-docker-host

# Grafana.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-grafana-password
GRAFANA_INSTALL_PLUGINS=alexanderzobnin-zabbix-app

# EASY Backup Manager.
EASY_BACKUP_PORT=8090
EASY_BACKUP_DB=easy_backup
EASY_BACKUP_DB_USER=easy_backup
EASY_BACKUP_DB_PASSWORD=change-this-easy-backup-password
EASY_BACKUP_JWT_SECRET=change-this-easy-backup-jwt-secret
EASY_BACKUP_CORS_ORIGIN=http://10.10.12.7:8090
URBACKUP_BASE_URL=http://host.docker.internal:55414
URBACKUP_PUID=1000
URBACKUP_PGID=1000

# Optional external integrations.
IMGBB_API_KEY=

# IA - NVR (busca de gravacoes por linguagem natural via Gemini)
GEMINI_API_KEY=
GEMINI_VIDEO_MODEL=gemini-2.5-flash
