generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  OPERATOR
  VIEWER
}

enum MachineStatus {
  ONLINE
  OFFLINE
  UNKNOWN
}

enum BackupStatus {
  OK
  RUNNING
  FAILED
  WARNING
  UNKNOWN
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  users     User[]
  machines  Machine[]
  alerts    Alert[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model User {
  id           String   @id @default(uuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(OPERATOR)
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Machine {
  id              String        @id @default(uuid())
  tenantId        String
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  urbackupClientId String?
  name            String
  ip              String?
  os              String?
  group           String?
  company         String?
  status          MachineStatus @default(UNKNOWN)
  backupStatus    BackupStatus  @default(UNKNOWN)
  lastBackupAt    DateTime?
  totalBytes      BigInt?
  usedBytes       BigInt?
  lastSeenAt      DateTime?
  backups         BackupJob[]
  alerts          Alert[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([tenantId, status])
  @@index([urbackupClientId])
}

model BackupJob {
  id              String       @id @default(uuid())
  machineId       String
  machine         Machine      @relation(fields: [machineId], references: [id])
  urbackupBackupId String?
  type            String
  status          BackupStatus @default(UNKNOWN)
  sizeBytes       BigInt?
  speedBytesSec   BigInt?
  startedAt       DateTime?
  finishedAt      DateTime?
  error           String?
  raw             Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}

model Alert {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  machineId String?
  machine   Machine? @relation(fields: [machineId], references: [id])
  severity  String
  title     String
  message   String
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(uuid())
  tenantId  String?
  userId    String?
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ip        String?
  createdAt DateTime @default(now())
}
