APP_NAME=SightOps Cam Snapshot
APP_ENV=development
APP_VERSION=1.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
LOG_JSON=0
ENABLE_DOCS=1

DATABASE_BACKEND=sqlite
DATABASE_URL=
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_NAME=sightops
DATABASE_USER=sightops
DATABASE_PASSWORD=change-me
DATA_DIR=data
SIGHTOPS_DB_PATH=data/sightops.db

# Use comma-separated origins in production, for example:
# ALLOWED_ORIGINS=https://sightops.example.com,https://admin.example.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
TRUSTED_PROXIES=127.0.0.1

AUTH_ENABLED=1
AUTH_REQUIRED=1
AUTH_LEGACY_OPEN=0
AUTH_TOKEN_TTL_HOURS=24
AUTH_DB_PATH=data/auth.db
AUTH_DATABASE_BACKEND=sqlite
AUTH_DATABASE_URL=

POSTGRES_ENABLED=1
POSTGRES_PORT=5432
POSTGRES_DB=sightops
POSTGRES_USER=sightops
POSTGRES_PASSWORD=change-me

IMGBB_API_KEY=

# IA - NVR (busca de gravacoes por linguagem natural via Gemini)
GEMINI_API_KEY=
GEMINI_VIDEO_MODEL=gemini-2.5-flash
GEMINI_SEARCH_TIMEOUT_SEC=60
GEMINI_MAX_CALLS_PER_MINUTE=8
GEMINI_MAX_CALLS_PER_HOUR=120
NVR_AI_SEARCH_WINDOW_MIN=5
NVR_AI_SEARCH_MAX_HOPS=3
NVR_AI_SEARCH_MAX_TOTAL_SEC=180

# Chave que cifra segredos operacionais guardados no banco (hoje: a senha das
# OLTs cadastradas em Implantacao > OLT). Pode ser qualquer frase longa.
#
# Se ficar vazia, o sistema gera uma sozinha em DATA_DIR/secret.key na primeira
# execucao e segue funcionando -- mas ai a chave mora ao lado do banco que ela
# protege, entao quem levar o volume leva os dois. Em producao, defina aqui.
#
# ATENCAO: trocar ou perder esta chave torna as senhas ja cifradas
# irrecuperaveis. Ela precisa entrar na rotina de backup junto com o banco.
SIGHTOPS_SECRET_KEY=
